            "text": "Uh, these are for you."
          },
          {
            "index": 41,
            "start": 117.075,
            "end": 119.786,
            "text": "Welcome to our country."
          },
          {
            "index": 42,
            "start": 122.122,
            "end": 123.248,
            "text": "Thank you."
          },
          {
            "index": 43,
            "start": 123.289,
            "end": 125.375,
            "text": "I'm from New York."
          },
          {
            "index": 44,
            "start": 125.417,
            "end": 128.753,
            "text": "Oh, okay. Sorry.\nWell, not a problem."
          },
          {
            "index": 45,
            "start": 128.837,
            "end": 130.714,
            "text": "I'll just use them\nto stop the bleeding."
          },
          {
            "index": 46,
            "start": 132.048,
            "end": 134.634,
            "text": "Okay.\nUh, baggage claim?"
          },
          {
            "index": 47,
            "start": 134.718,
            "end": 136.72,
            "text": "- Okay.\n- Okay."
          },
          {
            "index": 48,
            "start": 141.766,
            "end": 142.684,
            "text": "No way."
          },
          {
            "index": 49,
            "start": 142.726,
            "end": 144.352,
            "text": "I'm telling you,\nshe went to the airport"
          }
