          },
          {
            "index": 17,
            "start": 99.516,
            "end": 101.434,
            "text": "С чего бы начать?"
          },
          {
            "index": 18,
            "start": 102.268,
            "end": 105.688,
            "text": "Это Джули. Джули, это Рэйчел."
