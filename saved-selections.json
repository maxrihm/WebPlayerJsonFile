          {
            "index": 16,
            "start": 96.554,
            "end": 98.014,
            "text": "Всё!"
          },
          {
            "index": 17,
            "start": 99.516,
            "end": 101.434,
            "text": "С чего бы начать?"
          },
          {
            "index": 18,
            "start": 102.268,
            "end": 105.688,
            "text": "Это Джули. Джули, это Рэйчел."
          },
          {
            "index": 19,
            "start": 106.648,
            "end": 107.482,
            "text": "Привет."
          },
          {
            "index": 20,
            "start": 110.485,
            "end": 114.072,
            "text": "Это... не для тебя."
          },
          {
            "index": 21,
            "start": 115.615,
            "end": 117.117,
            "text": "Это для тебя."
          },
          {
            "index": 22,
            "start": 117.575,
            "end": 119.786,
            "text": "Добро пожаловать в нашу страну."
          },
          {
            "index": 23,
            "start": 122.33,
            "end": 125.333,
            "text": "Спасибо. Я из Нью-Йорка."
          },
          {
            "index": 24,
            "start": 127.961,
            "end": 130.713,
            "text": "Ладно. Тогда используем их,\nчтобы остановить кровотечение."
          },
          {
            "index": 25,
            "start": 132.423,
            "end": 134.675,
            "text": "Ладно. Пойдем за багажом?"
          },
          {
            "index": 26,
            "start": 134.676,
            "end": 136.094,
            "text": "- Давай.\n- Хорошо."
          },
          {
            "index": 27,
            "start": 141.85,
            "end": 144.476,
            "text": "- Да ладно.\n- Говорю тебе, она поехала в аэропорт."
          },
          {
            "index": 28,
            "start": 144.477,
            "end": 146.353,
            "text": "И она готова к отношениям с Россом."
          },
          {
            "index": 29,
            "start": 146.354,
            "end": 150.066,
            "text": "Ничего себе. Вот это новость. Огромная..."
          },
          {
            "index": 30,
            "start": 150.567,
            "end": 152.861,
            "text": "Это даже больше, чем огромная. Это как..."
          }
        ],
        "bottom": [
          {
            "index": 29,
            "start": 89.839,
            "end": 91.257,
            "text": "Oh, look at that.\nYes, I am."
          },
          {
            "index": 30,
            "start": 91.341,
            "end": 92.759,
            "text": "Anyway, enough about me,\nenough about me"
          },
          {
            "index": 31,
            "start": 92.842,
            "end": 94.26,
            "text": "Mr. Back-From-The-Orient."
          },
          {
            "index": 32,
            "start": 94.344,
            "end": 96.054,
            "text": "Come on, I want\nto hear everything."
          },
          {
            "index": 33,
            "start": 96.137,
            "end": 97.305,
            "text": "Everything."
          },
          {
            "index": 34,
            "start": 98.431,
            "end": 101.017,
            "text": "Well, uh,\nwhere do I start?"
          },
          {
            "index": 35,
            "start": 101.059,
            "end": 103.395,
            "text": "Um, well,\nthis is Julie."
          },
          {
            "index": 36,
            "start": 103.478,
            "end": 105.605,
            "text": "Uh, Julie,\nthis is Rachel."
          },
          {
            "index": 37,
            "start": 106.69,
            "end": 107.649,
            "text": "Hi."
          },
          {
            "index": 38,
            "start": 109.025,
            "end": 110.402,
            "text": "Uh...oh!"
          },
          {
            "index": 39,
            "start": 110.443,
            "end": 114.906,
            "text": "Uh, these are..\nthese are...aren't for you."
