            "end": 94.26,
            "text": "Mr. Back-From-The-Orient."
          },
          {
            "index": 32,
            "start": 94.344,
            "end": 96.054,
            "text": "Come on, I want\nto hear everything."
          },
          {
            "index": 33,
            "start": 96.137,
            "end": 97.305,
            "text": "Everything."
          },
          {
            "index": 34,
            "start": 98.431,
            "end": 101.017,
            "text": "Well, uh,\nwhere do I start?"
          },
          {
            "index": 35,
            "start": 101.059,
            "end": 103.395,
            "text": "Um, well,\nthis is Julie."
          },
          {
            "index": 36,
            "start": 103.478,
