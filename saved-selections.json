          {
            "index": 44,
            "start": 125.417,
            "end": 128.753,
            "text": "Oh, okay. Sorry.\nWell, not a problem."
          },
          {
            "index": 45,
            "start": 128.837,
            "end": 130.714,
            "text": "I'll just use them\nto stop the bleeding."
